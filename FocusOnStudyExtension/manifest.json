{
  "manifest_version": 3,
  "name": "FocusOnStudy",
  "version": "1.0",
  "description": "Block distracting websites during study sessions.",
  "permissions": [
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "*://*.youtube.com/*",
    "*://*.gmail.com/*"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "focus_rules",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  }
}
